UserInputService.InputEnded:connect(function(input, gameProcessed)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		mouseDown = nil

		if draggingOre then
			-- Was dragging: release ore
			network.send("endDrag", draggingOre)
			draggingOre = nil
		end
		-- Short click on ore: no longer collects

		orePendingDrag = nil
		orePendingDragTime = nil
	elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
		if mouseDownR then
			mouseDownR = nil
			-- no longer used for anything, but kept here just incase
		end
	end
end)

-- Drag threshold check + ore movement
RunService.RenderStepped:Connect(function()
	-- Promote pending ore click to drag if held long enough
	if orePendingDrag and not draggingOre then
		if tick() - orePendingDragTime >= DRAG_THRESHOLD then
			draggingOre = orePendingDrag
			orePendingDrag = nil
			orePendingDragTime = nil
			network.send("startDrag", draggingOre)
		end
	end

	-- Move dragged ore to follow mouse over terrain
	if draggingOre and draggingOre.Parent then
		local location = UserInputService:GetMouseLocation()
		local unitRay = camera:ViewportPointToRay(location.X, location.Y)
		local result = workspace:Raycast(unitRay.Origin, unitRay.Direction * 500, terrainOnlyParams)
		if result then
			draggingOre.CFrame = CFrame.new(result.Position + Vector3.new(0, 2, 0))
		end
	end
end)

